<Window
    x:Class="CodexBar.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Win CodexBar">
    <Grid x:Name="RootLayout" Background="#FF252527">
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="CustomTitleBar" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="84" />
            </Grid.ColumnDefinitions>

            <Grid
                x:Name="TitleBarDragRegion"
                Grid.Column="0"
                Background="Transparent">
                <TextBlock Text="Win CodexBar" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#FFB9A7E8" />
            </Grid>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Spacing="7">
                <Button
                    Width="12"
                    Height="12"
                    MinWidth="12"
                    MinHeight="12"
                    Padding="0"
                    BorderThickness="0"
                    CornerRadius="6"
                    Background="#FFFFBD2E"
                    Click="MinimizeCircleButton_Click">
                    <ToolTipService.ToolTip>Minimize</ToolTipService.ToolTip>
                </Button>
                <Button
                    Width="12"
                    Height="12"
                    MinWidth="12"
                    MinHeight="12"
                    Padding="0"
                    BorderThickness="0"
                    CornerRadius="6"
                    Background="#FF28C840"
                    Click="ZoomCircleButton_Click">
                    <ToolTipService.ToolTip>Zoom</ToolTipService.ToolTip>
                </Button>
                <Button
                    Width="12"
                    Height="12"
                    MinWidth="12"
                    MinHeight="12"
                    Padding="0"
                    BorderThickness="0"
                    CornerRadius="6"
                    Background="#FFFF5F57"
                    Click="CloseCircleButton_Click">
                    <ToolTipService.ToolTip>Hide</ToolTipService.ToolTip>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Padding="10,0,10,10">
            <Border
                x:Name="HudView"
                Padding="11,9"
                Background="#FF1F1C24"
                BorderBrush="#997D62C7"
                BorderThickness="1"
                CornerRadius="14">
                <Grid RowSpacing="7">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer
                        x:Name="HudScrollViewer"
                        Grid.Row="0"
                        VerticalScrollBarVisibility="Hidden"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Auto">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        x:Name="HudHeaderText"
                                        Text="Codex"
                                        FontSize="17"
                                        FontWeight="SemiBold"
                                        MaxLines="2"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" ColumnSpacing="6">
                                    <TextBlock
                                        x:Name="ModelPageText"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="#FFB9A7E8"
                                        FontSize="11"
                                        TextAlignment="Right"
                                        TextWrapping="NoWrap"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Grid>

                            <TextBlock x:Name="HudMetaText" Grid.Row="1" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />

                            <Grid
                                x:Name="ModelContentPanel"
                                Grid.Row="2"
                                Grid.RowSpan="3"
                                RowSpacing="4">
                                <Grid.RenderTransform>
                                    <TranslateTransform x:Name="ModelContentTransform" />
                                </Grid.RenderTransform>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CurrentWindowLabelText" Text="Current" FontWeight="SemiBold" Foreground="#FFEDE7FF" />
                                    <TextBlock x:Name="CurrentWindowPercentText" Grid.Column="1" FontWeight="SemiBold" />
                                </Grid>

                                <Grid x:Name="CurrentWindowTrackRoot" Grid.Row="1" Height="6">
                                    <Border Background="#FF30283A" BorderBrush="#FF5A4A74" BorderThickness="1" CornerRadius="3" />
                                    <Border x:Name="CurrentWindowFillBar" Background="#FF8D78D6" HorizontalAlignment="Left" CornerRadius="3" />
                                    <Border x:Name="CurrentWindowSweepBar" Background="#FFC8B9FF" Opacity="0.3" IsHitTestVisible="False" HorizontalAlignment="Left" />
                                </Grid>

                                <TextBlock x:Name="CurrentWindowText" Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                                <Grid Grid.Row="3" Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="WeeklyWindowLabelText" Text="Weekly" FontWeight="SemiBold" Foreground="#FFEDE7FF" />
                                    <TextBlock x:Name="WeeklyWindowPercentText" Grid.Column="1" FontWeight="SemiBold" />
                                </Grid>

                                <Grid x:Name="WeeklyWindowTrackRoot" Grid.Row="4" Height="6">
                                    <Border Background="#FF30283A" BorderBrush="#FF5A4A74" BorderThickness="1" CornerRadius="3" />
                                    <Border x:Name="WeeklyWindowFillBar" Background="#FF8D78D6" HorizontalAlignment="Left" CornerRadius="3" />
                                    <Border x:Name="WeeklyWindowSweepBar" Background="#FFC8B9FF" Opacity="0.3" IsHitTestVisible="False" HorizontalAlignment="Left" />
                                </Grid>

                                <TextBlock x:Name="WeeklyWindowText" Grid.Row="5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </Grid>

                            <Grid Grid.Row="5" ColumnSpacing="8" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Credits" FontWeight="SemiBold" />
                                <TextBlock x:Name="CreditsText" Grid.Column="1" TextWrapping="Wrap" />
                            </Grid>

                            <Grid Grid.Row="6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Account" FontWeight="SemiBold" />
                                <TextBlock x:Name="AccountText" Grid.Column="1" TextWrapping="Wrap" />
                            </Grid>

                            <TextBlock x:Name="ErrorText" Grid.Row="7" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" />
                        </Grid>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Spacing="6">
                        <Button Content="Settings" Click="SettingsButton_Click" />
                        <Button Content="Quit" Click="QuitButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="SettingsView" RowSpacing="10" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="SemiBold" />
                <CheckBox x:Name="CodexEnabledCheckBox" Grid.Row="1" Content="Enable Codex" />

                <Grid Grid.Row="2" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="98" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Refresh interval" VerticalAlignment="Center" />
                    <NumberBox
                        x:Name="RefreshIntervalSecondsNumberBox"
                        Grid.Column="1"
                        Minimum="1"
                        Maximum="3600"
                        SmallChange="1"
                        LargeChange="10"
                        SpinButtonPlacementMode="Inline" />
                    <TextBlock Grid.Column="2" Text="s" VerticalAlignment="Center" />
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                    <Button Content="Cancel" Click="CancelSettingsButton_Click" />
                    <Button Content="Save" Click="SaveSettingsButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
